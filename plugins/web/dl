#!/usr/bin/env bash
set -uo pipefail
: "${CLIXR_ROOT:=$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)}"
export CLIXR_LIB="$CLIXR_ROOT/lib"
. "$CLIXR_LIB/colors.sh"; . "$CLIXR_LIB/ui.sh"; . "$CLIXR_LIB/platform.sh"
. "$CLIXR_LIB/utils.sh"; . "$CLIXR_LIB/network.sh"; . "$CLIXR_LIB/crypto.sh"
# desc: Simple download with progress


url="${1:?usage: clixr dl <url> [out]}"
def="$(basename "${url%%\?*}")"; [ -z "$def" ] && def="download"
out="${2:-$def}"
require_cmd curl || exit 1
ui_info "downloading → $out"
curl -fL --progress-bar "$url" -o "$out" && ui_ok "saved $out ($(human_bytes "$(wc -c < "$out" 2>/dev/null || echo 0)"))"
